{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "dahasen-maker",
  "pages_build_output_dir": "dist/public",
  "compatibility_date": "2026-03-17",
  "vars": {
    "VITE_GOOGLE_AUTH_ENABLED": "true"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "dahasen-maker-db",
      "database_id": "30318e12-6a90-43f3-a9b5-224dc5af4dfd",
      "preview_database_id": "REPLACE_WITH_PREVIEW_DATABASE_ID",
      "migrations_dir": "migrations"
    }
  ]
}
